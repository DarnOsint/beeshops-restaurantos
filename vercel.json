{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/stock-check",
      "schedule": "0 6 * * *"
    }
  ]
}